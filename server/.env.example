# Server Configuration
PORT=8000
NODE_ENV=development

# Database Configuration
DB_PATH=./data/socio-copy.db

# File Storage Configuration  
UPLOAD_DIR=./uploads

# Supabase Configuration
SUPABASE_URL=https://vkappuaapscvteexogtp.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here
SUPABASE_DB_URL=postgresql://postgres:<password>@<host>:5432/postgres?sslmode=require
DB_SSL=true
APP_URL=http://localhost:3000

# Note: Replace SUPABASE_SERVICE_ROLE_KEY with your actual service role key from Supabase dashboard
# This is different from the anon key and has elevated permissions
# SUPABASE_DB_URL is used by the migration runner (npm run migration:up).

# Email Service (Resend) - https://resend.com
RESEND_API_KEY=your_resend_api_key_here
EMAIL_FROM_ADDRESS=SOCIO <noreply@socio.christuniversity.in>
EMAIL_REPLY_TO=support@socio.christuniversity.in
PUBLIC_APP_URL=https://socio.christuniversity.in

# Google Gemini AI - https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# CORS Configuration
ALLOWED_ORIGINS=https://socio.christuniversity.in,https://sociodev.vercel.app,http://localhost:3000,http://127.0.0.1:3000
ALLOWED_ORIGIN_PATTERNS=^https://.*\.vercel\.app$,^https://.*\.christuniversity\.in$
